# ============================================================================
# NanoClaw Host Container Configuration
# ============================================================================
# Copy this file to .env (in the same directory as docker-compose.host.yml)
# and fill in the required values before running:
#   docker compose -f docker-compose.host.yml up
# ============================================================================

# ---- REQUIRED: Host Paths ----
# When NanoClaw spawns agent containers, it passes volume mount paths to
# Docker. Because agent containers are siblings (not children), these paths
# must be HOST filesystem paths, not paths inside the NanoClaw container.
#
# Use the path format your Docker daemon expects:
#   Docker Desktop (WSL 2 backend): /c/Users/sean/... (lowercase drive, forward slashes)
#   Linux Docker:                   /home/sean/...

# Full host path to this NanoClaw git repository
DOCKER_HOST_REPO_PATH=/c/Data/Ext/Git/nanoclaw

# Full host path to the persistent state directory (nanoclaw-host/)
DOCKER_HOST_STATE_PATH=/c/Users/sean/nanoclaw-host

# ---- REQUIRED: Persistent State Directory ----
# Path to the nanoclaw-host/ directory for the docker-compose volume mount.
# Can be absolute or relative to the docker-compose.host.yml file.
# This is the SAME directory as DOCKER_HOST_STATE_PATH, but in a format
# docker-compose can use (Windows path or relative path).
NANOCLAW_HOST_DIR=../nanoclaw-host

# ---- REQUIRED: Claude Credentials (choose one) ----
# Claude Pro/Max subscription: run `claude setup-token` to get the token
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token

# OR Anthropic API key (from https://console.anthropic.com/)
# ANTHROPIC_API_KEY=sk-ant-...

# ---- OPTIONAL: NanoClaw Configuration ----
# These are auto-merged into the state .env on each startup.

# Name the assistant responds to (used in @mention trigger pattern)
ASSISTANT_NAME=Andy

# Set to "true" if the assistant has its own phone number (solo WhatsApp)
# ASSISTANT_HAS_OWN_NUMBER=false

# Timezone for scheduled tasks (IANA format)
# TZ=America/New_York

# Log verbosity: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info

# ---- OPTIONAL: Channel Credentials ----
# Uncomment and fill in when adding channels via /add-telegram, /add-slack, etc.
# These are auto-merged into state/.env on startup.

# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# DISCORD_BOT_TOKEN=MTIz...
